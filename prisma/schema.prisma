// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FACILITATOR
  PARTICIPANT
  OBSERVER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum CaseLanguage {
  RU
  EN
}

enum SessionStatus {
  DRAFT
  READY
  COMPLETED
}

enum ParticipantType {
  PARTICIPANT
  OBSERVER
  FACILITATOR
}

enum NegotiationState {
  PREPARATION
  PREPARATION_RUNNING
  PREPARATION_PAUSED
  READY_TO_START
  RUNNING
  PAUSED
  FINISHED
}

enum TrainingEventStatus {
  DRAFT
  LOBBY_OPEN
  SESSION_CREATED
  COMPLETED
  CANCELLED
}

enum EventParticipantPreference {
  UNDECIDED
  PLAY
  OBSERVE
  FACILITATE
}

enum RecordingStatus {
  NOT_STARTED
  STARTING
  RECORDING
  PAUSED
  PROCESSING
  COMPLETED
  FAILED
  STOPPED
}

enum RecordingType {
  AUDIO_ONLY
  VIDEO_COMPOSITE
}

enum CompressionStatus {
  NOT_STARTED
  COMPRESSING
  COMPLETED
  FAILED
  SKIPPED
}

enum TranscriptSource {
  MANUAL
  GENERATED
}

enum TranscriptStatus {
  QUEUED
  DOWNLOADING_RECORDING
  COMPRESSING_AUDIO
  TRANSCRIBING
  COMPLETED
  FAILED
}

enum AiAnalysisStatus {
  QUEUED
  ANALYZING
  COMPLETED
  FAILED
}

enum VisibilityLevel {
  PUBLIC
  PRIVATE
}

enum ExternalService {
  LIVEKIT
  OPENAI
  YANDEX_OBJECT_STORAGE
  FFMPEG
  APP
}

enum ExternalServiceEventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ExternalServiceErrorCode {
  AUTH_ERROR
  PERMISSION_DENIED
  QUOTA_EXCEEDED
  BILLING_LIMIT
  RATE_LIMIT
  CONFIG_MISSING
  NETWORK_ERROR
  STORAGE_UPLOAD_FAILED
  STORAGE_DOWNLOAD_FAILED
  STORAGE_OBJECT_NOT_FOUND
  RECORDING_START_FAILED
  RECORDING_STOP_FAILED
  RECORDING_STATUS_FAILED
  TRANSCRIPTION_FAILED
  TRANSCRIPTION_FILE_TOO_LARGE
  COMPRESSION_FAILED
  FFMPEG_MISSING
  UNKNOWN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  // Legacy session-scoped role — kept for existing seed/facilitator checks.
  // Do not use for access control; use globalRole + status instead.
  role         UserRole @default(PARTICIPANT)
  // Account-level role: "USER" | "ADMIN"
  globalRole   String   @default("USER")
  // Account status: "PENDING_APPROVAL" | "ACTIVE" | "REJECTED" | "BLOCKED"
  status       String   @default("PENDING_APPROVAL")

  // UI language preference: "ru" | "en"
  preferredLocale  String    @default("ru")

  lastLoginAt      DateTime?
  approvedAt       DateTime?
  approvedByUserId String?
  rejectedAt       DateTime?
  rejectedByUserId String?
  blockedAt        DateTime?
  blockedByUserId  String?
  approvalComment  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  negotiationCases    NegotiationCase[]    @relation("CaseFacilitator")
  createdNegotiationCases NegotiationCase[] @relation("CaseCreator")
  facilitatedSessions Session[]            @relation("SessionFacilitator")
  hostedTrainingEvents TrainingEvent[]     @relation("TrainingEventHost")
  facilitatedTrainingEvents TrainingEvent[] @relation("TrainingEventFacilitator")
  eventParticipants   EventParticipant[]
  sessionParticipants SessionParticipant[]
  videoProviderIdentities VideoProviderIdentity[]
  userSessions        UserSession[]
  adminActions        AdminActionLog[]     @relation("AdminActionActor")
  targetedAdminActions AdminActionLog[]    @relation("AdminActionTarget")
  userConsents        UserConsent[]
  eventInvitesSent     EventInvite[]       @relation("EventInviteSender")
  eventInvitesReceived EventInvite[]       @relation("EventInvitee")
  sessionInvitesSent   SessionInvite[]     @relation("SessionInviteSender")
  sessionInvitesReceived SessionInvite[]   @relation("SessionInvitee")
}

model UserSession {
  id               String    @id @default(cuid())
  userId           String
  sessionTokenHash String    @unique
  expiresAt        DateTime
  createdAt        DateTime  @default(now())
  lastSeenAt       DateTime?
  userAgent        String?
  ipHash           String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VideoProviderIdentity {
  id                      String   @id @default(cuid())
  provider                String
  userId                  String
  providerUsername        String
  providerApplicationName String
  status                  String
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  lastUsedAt              DateTime?
  lastProvisioningError   String?
  metadata                Json?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, userId])
  @@unique([provider, providerUsername])
  @@index([userId])
}

model NegotiationCase {
  id                       String       @id @default(cuid())
  title                    String
  description              String       @db.Text
  businessContext          String       @db.Text
  publicInstructions       String       @db.Text
  targetSkills             String       @db.Text
  difficulty               Difficulty   @default(MEDIUM)
  caseLanguage             CaseLanguage @default(EN)
  defaultPreparationDurationSeconds Int @default(300)
  defaultDurationSeconds            Int @default(900)
  facilitatorId                     String
  createdByUserId                   String?
  visibility                        VisibilityLevel @default(PRIVATE)
  deletedAt                DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  facilitator    User            @relation("CaseFacilitator", fields: [facilitatorId], references: [id], onDelete: Restrict)
  createdByUser  User?           @relation("CaseCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  roles          CaseRole[]
  sessions       Session[]
  trainingEvents TrainingEvent[]

  @@index([createdByUserId])
  @@index([visibility])
}

model CaseRole {
  id                  String   @id @default(cuid())
  negotiationCaseId   String
  name                String
  privateInstructions String   @db.Text
  objectives          String   @db.Text
  constraints         String   @db.Text
  hiddenInfo          String   @db.Text
  fallbackPosition    String   @db.Text
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  negotiationCase NegotiationCase @relation(fields: [negotiationCaseId], references: [id], onDelete: Cascade)

  @@index([negotiationCaseId])
}

model Session {
  id                         String           @id @default(cuid())
  negotiationCaseId          String
  facilitatorId              String
  title                      String
  snapshotCaseTitle          String
  snapshotBusinessContext    String           @db.Text
  snapshotPublicInstructions String           @db.Text
  snapshotCaseLanguage       CaseLanguage
  status                     SessionStatus    @default(DRAFT)
  livekitRoomName            String?          @unique
  negotiationState               NegotiationState @default(PREPARATION)
  preparationDurationSeconds     Int              @default(300)
  durationSeconds                  Int              @default(900)
  preparationStartedAt             DateTime?
  preparationEndedAt               DateTime?
  preparationTimerStartedAt        DateTime?
  preparationPausedAt              DateTime?
  preparationTotalPausedSeconds    Int              @default(0)
  negotiationStartedAt             DateTime?
  negotiationEndedAt               DateTime?
  timerStartedAt                   DateTime?
  pausedAt                         DateTime?
  totalPausedSeconds               Int              @default(0)
  startedAt                  DateTime?
  endedAt                    DateTime?
  deletedAt                  DateTime?
  visibility                 VisibilityLevel  @default(PRIVATE)
  eventId                    String?
  sequenceNumber            Int?
  roomLabel                 String?
  createdFromEventAt        DateTime?
  closedByEventAt            DateTime?
  closedByEventId            String?
  closeReason                String?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  negotiationCase NegotiationCase      @relation(fields: [negotiationCaseId], references: [id], onDelete: Restrict)
  facilitator     User                 @relation("SessionFacilitator", fields: [facilitatorId], references: [id], onDelete: Restrict)
  event           TrainingEvent?         @relation(fields: [eventId], references: [id], onDelete: SetNull)
  sessionRoles    SessionRole[]
  participants    SessionParticipant[]
  recording       Recording?
  transcript      Transcript?
  aiAnalysis      AiAnalysis?
  pauseIntervals  SessionPauseInterval[]
  eventParticipants EventParticipant[]   @relation("EventAssignedSession")
  sessionInvites    SessionInvite[]

  @@index([negotiationCaseId])
  @@index([facilitatorId])
  @@index([eventId])
}

model SessionPauseInterval {
  id        String    @id @default(cuid())
  sessionId String
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model SessionRole {
  id                  String   @id @default(cuid())
  sessionId           String
  name                String
  privateInstructions String   @db.Text
  objectives          String   @db.Text
  constraints         String   @db.Text
  hiddenInfo          String   @db.Text
  fallbackPosition    String   @db.Text
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  session             Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionParticipants SessionParticipant[]

  @@index([sessionId])
}

model SessionParticipant {
  id                 String          @id @default(cuid())
  sessionId          String
  userId             String?
  sessionRoleId      String?
  eventParticipantId String?
  type               ParticipantType
  joinToken          String          @unique
  displayName        String
  notes              String          @default("") @db.Text
  joinedAt           DateTime?
  lastSeenAt         DateTime?
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @updatedAt

  session            Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionRole        SessionRole?        @relation(fields: [sessionRoleId], references: [id], onDelete: SetNull)
  eventParticipant   EventParticipant?   @relation("EventParticipantLink", fields: [eventParticipantId], references: [id], onDelete: SetNull)
  eventAssignment    EventParticipant?   @relation("EventParticipantAssignment")
  transcriptSegments TranscriptSegment[]

  @@index([sessionId])
  @@index([userId])
  @@index([sessionId, userId])
  @@index([sessionRoleId])
  @@index([eventParticipantId])
}

model TrainingEvent {
  id                     String               @id @default(cuid())
  title                  String
  description            String?              @db.Text
  scheduledAt            DateTime?
  timeZone               String               @default("UTC")
  hostUserId             String?
  facilitatorUserId      String?
  visibility             VisibilityLevel      @default(PRIVATE)
  status                 TrainingEventStatus  @default(LOBBY_OPEN)
  publicJoinCode         String               @unique
  hostToken              String               @unique
  lobbyRoomName          String?
  selectedCaseId         String?
  estimatedEventDurationSeconds Int?          @default(7200)
  assignmentDraft        Json?
  completedAt            DateTime?
  completedBy            String?
  completionReason       String?
  endedMessage           String?
  createdAt              DateTime             @default(now())
  updatedAt              DateTime             @updatedAt
  deletedAt              DateTime?

  selectedCase NegotiationCase?   @relation(fields: [selectedCaseId], references: [id], onDelete: SetNull)
  hostUser     User?              @relation("TrainingEventHost", fields: [hostUserId], references: [id], onDelete: SetNull)
  facilitator  User?              @relation("TrainingEventFacilitator", fields: [facilitatorUserId], references: [id], onDelete: SetNull)
  participants EventParticipant[]
  sessions     Session[]
  invites      EventInvite[]

  @@index([hostUserId])
  @@index([facilitatorUserId])
  @@index([selectedCaseId])
}

model EventParticipant {
  id                           String                     @id @default(cuid())
  eventId                      String
  userId                       String?
  displayName                  String
  email                        String?
  participantToken             String                     @unique
  preference                   EventParticipantPreference @default(UNDECIDED)
  isHost                       Boolean                    @default(false)
  wantsToPlay                  Boolean                    @default(false)
  wantsToObserve               Boolean                    @default(false)
  wantsToFacilitate            Boolean                    @default(false)
  joinedAt                     DateTime?
  lastSeenAt                   DateTime?
  assignedSessionId            String?
  assignedSessionParticipantId String?                    @unique
  createdAt                    DateTime                   @default(now())
  updatedAt                    DateTime                   @updatedAt

  event                      TrainingEvent       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user                       User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  assignedSession            Session?            @relation("EventAssignedSession", fields: [assignedSessionId], references: [id], onDelete: SetNull)
  assignedSessionParticipant SessionParticipant? @relation("EventParticipantAssignment", fields: [assignedSessionParticipantId], references: [id], onDelete: SetNull)
  linkedSessionParticipants  SessionParticipant[] @relation("EventParticipantLink")

  @@index([eventId])
  @@index([userId])
  @@index([eventId, userId])
  @@index([assignedSessionId])
  // DB-level duplicate prevention: multiple NULLs allowed (guest rows), unique per (eventId, userId) pair when userId is set.
  // TODO: Replace with a partial unique index on eventId+userId WHERE userId IS NOT NULL once Prisma supports partial indexes natively.
}

model EventInvite {
  id              String        @id @default(cuid())
  eventId         String
  userId          String?
  invitedEmail    String?
  invitedEmailNormalized String?
  displayLabel    String?
  invitedByUserId String
  createdAt       DateTime      @default(now())

  event     TrainingEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)
  user      User?         @relation("EventInvitee", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User          @relation("EventInviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([eventId, userId])
  @@unique([eventId, invitedEmailNormalized])
  @@index([eventId])
  @@index([userId])
  @@index([invitedEmailNormalized])
}

model SessionInvite {
  id              String   @id @default(cuid())
  sessionId       String
  userId          String?
  invitedEmail    String?
  invitedEmailNormalized String?
  displayLabel    String?
  invitedByUserId String
  createdAt       DateTime @default(now())

  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user      User?   @relation("SessionInvitee", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy User    @relation("SessionInviteSender", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  @@unique([sessionId, userId])
  @@unique([sessionId, invitedEmailNormalized])
  @@index([sessionId])
  @@index([userId])
  @@index([invitedEmailNormalized])
}

model Recording {
  id                   String             @id @default(cuid())
  sessionId            String             @unique
  provider             String             @default("LIVEKIT_CLOUD")
  egressId             String?
  status               RecordingStatus    @default(NOT_STARTED)
  recordingType        RecordingType      @default(AUDIO_ONLY)
  fileUrl              String?
  fileKey              String?
  fileName             String?
  mimeType             String?
  originalSizeBytes    Int?
  compressedFileKey    String?
  compressedFileName   String?
  compressedMimeType   String?
  compressedSizeBytes  Int?
  compressionStatus    CompressionStatus?
  compressionError     String?
  startedAt            DateTime?
  endedAt              DateTime?
  errorMessage         String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  transcript Transcript?
}

model Transcript {
  id                          String           @id @default(cuid())
  sessionId                   String           @unique
  recordingId                 String?          @unique
  source                      TranscriptSource
  status                      TranscriptStatus @default(COMPLETED)
  text                        String           @default("") @db.Text
  diarizedText                String?          @db.Text
  language                    String?
  originalFileName            String?
  originalMimeType            String?
  transcriptionModel          String?
  hasSpeakerDiarization       Boolean          @default(false)
  speakerMapping              Json?
  // Speaker mapping workflow: NOT_REQUIRED | REQUIRED | AUTO_SUGGESTED | CONFIRMED | NEEDS_REVIEW | PARTIALLY_MAPPED | FAILED
  speakerMappingStatus        String           @default("NOT_REQUIRED")
  speakerMappingConfirmedAt   DateTime?
  speakerMappingConfirmedBy   String?
  // Diarization tracking: NOT_REQUESTED | REQUESTED | COMPLETED | FAILED | NO_SPEAKERS_DETECTED | SINGLE_SPEAKER_ONLY
  diarizationStatus           String?
  diarizationProvider         String?
  diarizationError            String?
  // Two-pass transcription strategy fields
  // strategy: diarize_only | quality_only | diarize_plus_quality
  strategy                    String?
  // qualityModel: model used in the quality pass (diarize_plus_quality or quality_only)
  qualityModel                String?
  // diarizationPassStatus: COMPLETED | FAILED
  diarizationPassStatus       String?
  // qualityPassStatus: OK | LOW_CONFIDENCE | FAILED | SKIPPED
  qualityPassStatus           String?
  // alignmentStatus: ALIGNED | PARTIAL | FAILED | SKIPPED
  alignmentStatus             String?
  // alignmentConfidence: 0..1 average alignment confidence across segments
  alignmentConfidence         Float?
  // Re-transcription versioning
  retranscribeCount           Int              @default(0)
  retranscribeHistory         Json?
  processingMetadata          Json?
  errorMessage                String?
  startedAt                   DateTime?
  completedAt                 DateTime?
  createdAt                   DateTime         @default(now())
  updatedAt                   DateTime         @updatedAt

  session   Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recording Recording?          @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  segments  TranscriptSegment[]
}

model TranscriptSegment {
  id                  String   @id @default(cuid())
  transcriptId        String
  speakerLabel        String?
  mappedParticipantId String?
  startSeconds        Float?
  endSeconds          Float?
  // text is the final text shown to users and AI (= diarized text or quality-aligned text)
  text                String   @db.Text
  // qualityText: text candidate from quality transcription pass (before confidence threshold)
  qualityText         String?  @db.Text
  // alignmentConfidence: per-segment confidence score from quality pass alignment (0..1)
  alignmentConfidence Float?
  // textSource: DIARIZED | QUALITY | MANUAL — which pass produced the final text
  textSource          String?
  orderIndex          Int
  // Mapping provenance: PROVIDER_DIARIZATION | CLUSTER_MAPPING | MIC_ACTIVITY | MANUAL_SEGMENT_OVERRIDE | MANUAL_CLUSTER_MAPPING | UNKNOWN
  mappingSource       String?
  mappingConfidence   Float?
  // When true, cluster mapping changes must not overwrite this segment
  mappingLocked       Boolean  @default(false)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transcript        Transcript          @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  mappedParticipant SessionParticipant? @relation(fields: [mappedParticipantId], references: [id], onDelete: SetNull)

  @@index([transcriptId])
  @@index([mappedParticipantId])
}

model AiAnalysis {
  id                          String           @id @default(cuid())
  sessionId                   String           @unique
  transcriptId                String?
  // Tracks which retranscribeCount version of the transcript this analysis was built on
  transcriptRetranscribeCount Int              @default(0)
  status                      AiAnalysisStatus @default(QUEUED)
  model                  String?
  language               String?
  executiveSummary       String?          @db.Text
  overallScore           Int?
  analysisJson           Json?
  rawModelOutput         Json?
  errorMessage           String?          @db.Text
  startedAt              DateTime?
  completedAt            DateTime?
  // Sharing / visibility
  visibility             String           @default("FACILITATOR_ONLY")
  sharedAnalysisJson     Json?
  sharedExecutiveSummary String?          @db.Text
  sharedAt               DateTime?
  sharedBy               String?
  unsharedAt             DateTime?
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ExternalServiceEvent {
  id          String                        @id @default(cuid())
  service     ExternalService
  severity    ExternalServiceEventSeverity
  errorCode   ExternalServiceErrorCode?
  title       String
  message     String                        @db.Text
  rawError    Json?
  sessionId   String?
  recordingId String?
  requestId   String?
  createdAt   DateTime                      @default(now())
  resolvedAt  DateTime?

  @@index([service])
  @@index([severity])
  @@index([sessionId])
  @@index([createdAt])
}

model UsageCounter {
  id          String          @id @default(cuid())
  service     ExternalService
  metric      String
  periodStart DateTime
  periodEnd   DateTime?
  value       Float
  unit        String
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([service, metric, periodStart])
}

model AdminActionLog {
  id          String   @id @default(cuid())
  adminUserId String
  targetUserId String?
  action      String
  comment     String?
  metadata    Json?
  createdAt   DateTime @default(now())

  adminUser User  @relation("AdminActionActor", fields: [adminUserId], references: [id], onDelete: Cascade)
  targetUser User? @relation("AdminActionTarget", fields: [targetUserId], references: [id], onDelete: SetNull)

  @@index([adminUserId])
  @@index([targetUserId])
  @@index([action])
  @@index([createdAt])
}

model UserConsent {
  id          String   @id @default(cuid())
  userId      String
  consentType String
  version     String   @default("1")
  acceptedAt  DateTime @default(now())
  ipHash      String?
  userAgent   String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([consentType])
}

model SessionParticipantAudioActivity {
  id                      String    @id @default(cuid())
  sessionId               String
  sessionParticipantId    String
  participantIdentity     String?
  startedAt               DateTime
  endedAt                 DateTime?
  startedOffsetSeconds    Float?
  endedOffsetSeconds      Float?
  source                  String    @default("LIVEKIT_ACTIVE_SPEAKER")
  confidence              Float?
  createdAt               DateTime  @default(now())

  @@index([sessionId])
  @@index([sessionParticipantId])
}
