// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  FACILITATOR
  PARTICIPANT
  OBSERVER
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum CaseLanguage {
  RU
  EN
}

enum SessionStatus {
  DRAFT
  READY
}

enum ParticipantType {
  PARTICIPANT
  OBSERVER
  FACILITATOR
}

enum NegotiationState {
  LOBBY
  RUNNING
  PAUSED
  FINISHED
}

enum RecordingStatus {
  NOT_STARTED
  STARTING
  RECORDING
  PAUSED
  PROCESSING
  COMPLETED
  FAILED
  STOPPED
}

enum RecordingType {
  AUDIO_ONLY
  VIDEO_COMPOSITE
}

enum CompressionStatus {
  NOT_STARTED
  COMPRESSING
  COMPLETED
  FAILED
  SKIPPED
}

enum TranscriptSource {
  MANUAL
  GENERATED
}

enum ExternalService {
  LIVEKIT
  OPENAI
  YANDEX_OBJECT_STORAGE
  FFMPEG
  APP
}

enum ExternalServiceEventSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum ExternalServiceErrorCode {
  AUTH_ERROR
  PERMISSION_DENIED
  QUOTA_EXCEEDED
  BILLING_LIMIT
  RATE_LIMIT
  CONFIG_MISSING
  NETWORK_ERROR
  STORAGE_UPLOAD_FAILED
  STORAGE_DOWNLOAD_FAILED
  STORAGE_OBJECT_NOT_FOUND
  RECORDING_START_FAILED
  RECORDING_STOP_FAILED
  RECORDING_STATUS_FAILED
  TRANSCRIPTION_FAILED
  TRANSCRIPTION_FILE_TOO_LARGE
  COMPRESSION_FAILED
  FFMPEG_MISSING
  UNKNOWN
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String?
  role         UserRole @default(PARTICIPANT)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  negotiationCases    NegotiationCase[]    @relation("CaseFacilitator")
  facilitatedSessions Session[]            @relation("SessionFacilitator")
  sessionParticipants SessionParticipant[]
}

model NegotiationCase {
  id                       String       @id @default(cuid())
  title                    String
  description              String       @db.Text
  businessContext          String       @db.Text
  publicInstructions       String       @db.Text
  targetSkills             String       @db.Text
  difficulty               Difficulty   @default(MEDIUM)
  caseLanguage             CaseLanguage @default(EN)
  defaultDurationSeconds   Int          @default(900)
  facilitatorId            String
  deletedAt                DateTime?
  createdAt                DateTime     @default(now())
  updatedAt                DateTime     @updatedAt

  facilitator User      @relation("CaseFacilitator", fields: [facilitatorId], references: [id], onDelete: Restrict)
  roles       CaseRole[]
  sessions    Session[]
}

model CaseRole {
  id                  String   @id @default(cuid())
  negotiationCaseId   String
  name                String
  privateInstructions String   @db.Text
  objectives          String   @db.Text
  constraints         String   @db.Text
  hiddenInfo          String   @db.Text
  fallbackPosition    String   @db.Text
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  negotiationCase NegotiationCase @relation(fields: [negotiationCaseId], references: [id], onDelete: Cascade)

  @@index([negotiationCaseId])
}

model Session {
  id                         String           @id @default(cuid())
  negotiationCaseId          String
  facilitatorId              String
  title                      String
  snapshotCaseTitle          String
  snapshotBusinessContext    String           @db.Text
  snapshotPublicInstructions String           @db.Text
  snapshotCaseLanguage       CaseLanguage
  status                     SessionStatus    @default(DRAFT)
  livekitRoomName            String?          @unique
  negotiationState           NegotiationState @default(LOBBY)
  durationSeconds            Int
  negotiationStartedAt       DateTime?
  negotiationEndedAt         DateTime?
  timerStartedAt             DateTime?
  pausedAt                   DateTime?
  totalPausedSeconds         Int              @default(0)
  startedAt                  DateTime?
  endedAt                    DateTime?
  deletedAt                  DateTime?
  createdAt                  DateTime         @default(now())
  updatedAt                  DateTime         @updatedAt

  negotiationCase NegotiationCase      @relation(fields: [negotiationCaseId], references: [id], onDelete: Restrict)
  facilitator     User                 @relation("SessionFacilitator", fields: [facilitatorId], references: [id], onDelete: Restrict)
  sessionRoles    SessionRole[]
  participants    SessionParticipant[]
  recording       Recording?
  transcript      Transcript?
  aiAnalysis      AiAnalysis?
  pauseIntervals  SessionPauseInterval[]

  @@index([negotiationCaseId])
  @@index([facilitatorId])
}

model SessionPauseInterval {
  id        String    @id @default(cuid())
  sessionId String
  startedAt DateTime
  endedAt   DateTime?
  createdAt DateTime  @default(now())

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

model SessionRole {
  id                  String   @id @default(cuid())
  sessionId           String
  name                String
  privateInstructions String   @db.Text
  objectives          String   @db.Text
  constraints         String   @db.Text
  hiddenInfo          String   @db.Text
  fallbackPosition    String   @db.Text
  sortOrder           Int      @default(0)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  session             Session              @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sessionParticipants SessionParticipant[]

  @@index([sessionId])
}

model SessionParticipant {
  id            String          @id @default(cuid())
  sessionId     String
  userId        String?
  sessionRoleId String?
  type          ParticipantType
  joinToken     String          @unique
  displayName   String
  notes         String          @default("") @db.Text
  joinedAt      DateTime?
  lastSeenAt    DateTime?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  session            Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user               User?               @relation(fields: [userId], references: [id], onDelete: SetNull)
  sessionRole        SessionRole?        @relation(fields: [sessionRoleId], references: [id], onDelete: SetNull)
  transcriptSegments TranscriptSegment[]

  @@index([sessionId])
  @@index([userId])
  @@index([sessionRoleId])
}

model Recording {
  id                   String             @id @default(cuid())
  sessionId            String             @unique
  provider             String             @default("LIVEKIT_CLOUD")
  egressId             String?
  status               RecordingStatus    @default(NOT_STARTED)
  recordingType        RecordingType      @default(AUDIO_ONLY)
  fileUrl              String?
  fileKey              String?
  fileName             String?
  mimeType             String?
  originalSizeBytes    Int?
  compressedFileKey    String?
  compressedFileName   String?
  compressedMimeType   String?
  compressedSizeBytes  Int?
  compressionStatus    CompressionStatus?
  compressionError     String?
  startedAt            DateTime?
  endedAt              DateTime?
  errorMessage         String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  session    Session     @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  transcript Transcript?
}

model Transcript {
  id                   String           @id @default(cuid())
  sessionId            String           @unique
  recordingId          String?          @unique
  source               TranscriptSource
  text                 String           @db.Text
  diarizedText         String?          @db.Text
  language             String?
  originalFileName     String?
  originalMimeType     String?
  transcriptionModel   String?
  hasSpeakerDiarization Boolean         @default(false)
  speakerMapping       Json?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  session   Session             @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  recording Recording?          @relation(fields: [recordingId], references: [id], onDelete: SetNull)
  segments  TranscriptSegment[]
}

model TranscriptSegment {
  id                  String   @id @default(cuid())
  transcriptId        String
  speakerLabel        String?
  mappedParticipantId String?
  startSeconds        Float?
  endSeconds          Float?
  text                String   @db.Text
  orderIndex          Int
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  transcript        Transcript          @relation(fields: [transcriptId], references: [id], onDelete: Cascade)
  mappedParticipant SessionParticipant? @relation(fields: [mappedParticipantId], references: [id], onDelete: SetNull)

  @@index([transcriptId])
  @@index([mappedParticipantId])
}

model AiAnalysis {
  id        String   @id @default(cuid())
  sessionId String   @unique
  summary   String?  @db.Text
  result    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model ExternalServiceEvent {
  id          String                        @id @default(cuid())
  service     ExternalService
  severity    ExternalServiceEventSeverity
  errorCode   ExternalServiceErrorCode?
  title       String
  message     String                        @db.Text
  rawError    Json?
  sessionId   String?
  recordingId String?
  requestId   String?
  createdAt   DateTime                      @default(now())
  resolvedAt  DateTime?

  @@index([service])
  @@index([severity])
  @@index([sessionId])
  @@index([createdAt])
}

model UsageCounter {
  id          String          @id @default(cuid())
  service     ExternalService
  metric      String
  periodStart DateTime
  periodEnd   DateTime?
  value       Float
  unit        String
  metadata    Json?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  @@index([service, metric, periodStart])
}
